{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Todo Reminder",
  "version": "0.1.0",
  "identifier": "com.lenvovo.todoreminder",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Todo Reminder",
        "width": 1180,
        "height": 760,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Lenvovo",
    "copyright": "Copyright © 2026 Lenvovo",
    "category": "Productivity",
    "shortDescription": "桌面任務提醒工具",
    "longDescription": "一個常駐桌面、能在正確時間提醒你的個人任務助理。支援自然語言時間解析、看板視圖、系統托盤常駐、Windows 原生通知。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
